// Guardião Conservador v2 — ADX +DI/-DI Panel

//@version=6
indicator("Guardião ADX Panel v2", overlay=false)

// === Parâmetros (validados backtest 7d 1m BTC-USD) ===
di_len      = input.int(14, "DI Período")
adx_len     = input.int(14, "ADX Suavização")
adx_thresh  = input.int(25, "ADX Threshold")
vol_sma_len = input.int(20, "Volume SMA Período")
vol_thresh  = input.float(1.0, "Volume Ratio Mínimo", step=0.1)

// === Cálculo ADX ===
[diplus, diminus, adx_val] = ta.dmi(di_len, adx_len)

// === Volume Ratio ===
vol_avg   = ta.sma(volume, vol_sma_len)
vol_ratio = volume / vol_avg

// === Crossover Detection ===
bull_cross = ta.crossover(diplus, diminus)
bear_cross = ta.crossunder(diplus, diminus)

// === DI Gap (proximidade do crossover) ===
gap = math.abs(diplus - diminus)
gap_color = gap < 5 ? color.new(#FFD600, 0) :
            gap < 10 ? color.new(#FFD600, 60) :
                        color.new(color.gray, 60)

// === Plot DI lines ===
plot(diplus,  "+DI", color=#00E676, linewidth=2)
plot(diminus, "-DI", color=#FF5252, linewidth=2)

// === ADX com cor dinâmica ===
adx_color = adx_val >= 25 ? color.new(#00E676, 0) :
            adx_val >= 20 ? color.new(#FFD600, 0) :
                            color.new(#FF5252, 0)
plot(adx_val, "ADX", color=adx_color, linewidth=3)

// === ADX area fill ===
plot(adx_val, "ADX Fill", display=display.none)
plot(25, "ADX Base", display=display.none)
fill(plot(adx_val, display=display.none), plot(25, display=display.none),
     color=adx_val >= 25 ? color.new(#00E676, 85) : color.new(#FF5252, 90))

// === Threshold ===
hline(adx_thresh, "Threshold", color=color.new(#FFD600, 40),
      linestyle=hline.style_dashed, linewidth=1)
hline(20, "Building", color=color.new(color.gray, 60),
      linestyle=hline.style_dotted, linewidth=1)

// === Gap plot (proximidade) ===
plot(gap, "Gap", color=gap_color, linewidth=1, style=plot.style_area,
     display=display.data_window)

// === Sinais no painel ===
plotshape(bull_cross and adx_val >= adx_thresh and vol_ratio >= vol_thresh,
          "Buy Signal", shape.triangleup, location.bottom,
          color.new(#00E676, 0), size=size.small)
plotshape(bear_cross and adx_val >= adx_thresh and vol_ratio >= vol_thresh,
          "Sell Signal", shape.triangledown, location.top,
          color.new(#FF1744, 0), size=size.small)
plotshape(bull_cross and (adx_val < adx_thresh or vol_ratio < vol_thresh),
          "Buy Blocked", shape.xcross, location.bottom,
          color.new(color.gray, 50), size=size.tiny)
plotshape(bear_cross and (adx_val < adx_thresh or vol_ratio < vol_thresh),
          "Sell Blocked", shape.xcross, location.top,
          color.new(color.gray, 50), size=size.tiny)

// === Info box ===
var table info = table.new(position.top_right, 2, 6,
     bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    // TP dinâmico
    tp = adx_val < 20 ? 0.30 :
         adx_val < 30 ? 0.40 :
         adx_val < 40 ? 0.50 :
                        0.60
    table.cell(info, 0, 0, "+DI",      text_color=#00E676, text_size=size.small)
    table.cell(info, 1, 0, str.tostring(diplus, "#.0"), text_color=#00E676, text_size=size.small)
    table.cell(info, 0, 1, "-DI",      text_color=#FF5252, text_size=size.small)
    table.cell(info, 1, 1, str.tostring(diminus, "#.0"), text_color=#FF5252, text_size=size.small)
    table.cell(info, 0, 2, "ADX",      text_color=adx_color, text_size=size.small)
    table.cell(info, 1, 2, str.tostring(adx_val, "#.0"), text_color=adx_color, text_size=size.small)
    table.cell(info, 0, 3, "Gap",      text_color=gap < 5 ? #FFD600 : color.gray, text_size=size.small)
    table.cell(info, 1, 3, str.tostring(gap, "#.1") + (gap < 5 ? " HOT" : ""), text_color=gap < 5 ? #FFD600 : color.gray, text_size=size.small)
    table.cell(info, 0, 4, "Vol",      text_color=vol_ratio >= vol_thresh ? #00E676 : #FF5252, text_size=size.small)
    table.cell(info, 1, 4, str.tostring(vol_ratio, "#.0") + "x", text_color=vol_ratio >= vol_thresh ? #00E676 : #FF5252, text_size=size.small)
    table.cell(info, 0, 5, "TP",       text_color=#FFD600, text_size=size.small)
    table.cell(info, 1, 5, str.tostring(tp, "#.00") + "%", text_color=#FFD600, text_size=size.small)
