// Guardião Conservador v2 — ADX +DI/-DI Crossover + Volume Filter

//@version=6
indicator("Guardião ADX Filter v2", overlay=true, max_lines_count=1)

// === Parâmetros ===
adx_len        = input.int(14, "ADX Período", minval=1)
adx_thresh     = input.int(25, "ADX Threshold", minval=1)
vol_sma_len    = input.int(20, "Volume SMA Período", minval=1)
vol_thresh     = input.float(1.0, "Volume Ratio Mínimo", step=0.1)

// === ADX / DI ===
[diplus, diminus, adx_val] = ta.dmi(adx_len, adx_len)

// === +DI/-DI Crossover ===
bull_cross = ta.crossover(diplus, diminus)
bear_cross = ta.crossunder(diplus, diminus)

// === Volume Filter ===
vol_avg    = ta.sma(volume, vol_sma_len)
vol_ratio  = volume / vol_avg
vol_ok     = vol_ratio >= vol_thresh

// === Sinais filtrados ===
buy_signal  = bull_cross and adx_val >= adx_thresh and vol_ok
sell_signal = bear_cross and adx_val >= adx_thresh and vol_ok

// === Sinais parciais (ADX ok, sem volume) ===
buy_weak  = bull_cross and adx_val >= adx_thresh and not vol_ok
sell_weak = bear_cross and adx_val >= adx_thresh and not vol_ok

// === Sinais rejeitados (ADX baixo) ===
buy_blocked  = bull_cross and adx_val < adx_thresh
sell_blocked = bear_cross and adx_val < adx_thresh

// === Labels dos sinais ===
plotshape(buy_signal,  "Compra",       shape.triangleup,   location.belowbar, color.new(#00E676, 0), size=size.small, text="BUY")
plotshape(sell_signal, "Venda",        shape.triangledown, location.abovebar, color.new(#FF1744, 0), size=size.small, text="SELL")
plotshape(buy_weak,   "Compra Fraca",  shape.triangleup,   location.belowbar, color.new(#FFD600, 0), size=size.tiny)
plotshape(sell_weak,  "Venda Fraca",   shape.triangledown, location.abovebar, color.new(#FFD600, 0), size=size.tiny)
plotshape(buy_blocked, "Compra Bloq.", shape.circle,       location.belowbar, color.new(color.gray, 40), size=size.tiny)
plotshape(sell_blocked,"Venda Bloq.",  shape.circle,       location.abovebar, color.new(color.gray, 40), size=size.tiny)

// === Fundo por estado do ADX ===
adx_trend    = adx_val >= adx_thresh
adx_building = adx_val >= 20 and adx_val < adx_thresh
bgcolor(adx_trend    ? color.new(#00E676, 93) :
        adx_building ? color.new(#FFD600, 95) :
                       color.new(#FF1744, 97))

// === Info box ===
var table info = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    gap = math.abs(diplus - diminus)
    table.cell(info, 0, 0, "+DI",   text_color=color.new(#00E676, 0), text_size=size.small)
    table.cell(info, 1, 0, str.tostring(diplus, "#.0"), text_color=color.new(#00E676, 0), text_size=size.small)
    table.cell(info, 0, 1, "-DI",   text_color=color.new(#FF1744, 0), text_size=size.small)
    table.cell(info, 1, 1, str.tostring(diminus, "#.0"), text_color=color.new(#FF1744, 0), text_size=size.small)
    table.cell(info, 0, 2, "ADX",   text_color=adx_trend ? color.new(#00E676, 0) : color.new(#FF1744, 0), text_size=size.small)
    table.cell(info, 1, 2, str.tostring(adx_val, "#.0"), text_color=adx_trend ? color.new(#00E676, 0) : color.new(#FF1744, 0), text_size=size.small)
    table.cell(info, 0, 3, "Gap",   text_color=gap < 5 ? color.new(#FFD600, 0) : color.gray, text_size=size.small)
    table.cell(info, 1, 3, str.tostring(gap, "#.0"), text_color=gap < 5 ? color.new(#FFD600, 0) : color.gray, text_size=size.small)
