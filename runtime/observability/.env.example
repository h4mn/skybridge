# Glitchtip — Variáveis de ambiente
# Copie para .env e ajuste os valores

# Banco de dados
DATABASE_URL=postgres://postgres@postgres:5432/glitchtip

# Valkey/Redis (opcional — sem ele, usa Redis embutido)
VALKEY_URL=redis://localhost:6379/0

# Segurança
SECRET_KEY=change-me-to-a-random-string

# Email (não necessário para uso local)
EMAIL_URL=smtp://localhost:25

# Domínio
GLITCHTIP_DOMAIN=http://localhost:8000
DEFAULT_FROM_EMAIL=noreply@localhost

# Funcionalidades
ENABLE_ADMIN=False
ENABLE_OPENAPI=False
GLITCHTIP_ENABLE_MCP=True
GLITCHTIP_ENABLE_DUCKDB=True
GLITCHTIP_ENABLE_LOGS=True
GLITCHTIP_ENABLE_UPTIME=True
PORT=8000
